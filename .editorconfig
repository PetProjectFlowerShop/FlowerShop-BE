root = true

# ----------------------------------------
# Default for all files
# ----------------------------------------
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4
max_line_length = 120

# ----------------------------------------
# Java
# ----------------------------------------
[*.java]
indent_style = space
indent_size = 4
max_line_length = 120

# ----------------------------------------
# XML / Spring config
# ----------------------------------------
[*.xml]
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

# ----------------------------------------
# Shell / scripts
# ----------------------------------------
[*.sh]
indent_style = space
indent_size = 2
end_of_line = lf

[*.bat]
indent_style = space
indent_size = 2
end_of_line = crlf

# ----------------------------------------
# Markdown / Docs
# ----------------------------------------
[*.md]
trim_trailing_whitespace = false
max_line_length = off
insert_final_newline = true

# ----------------------------------------
# Binary files - ignore formatting
# ----------------------------------------
[*.{jar,war,zip,png,jpg,jpeg,gif,ico,pdf}]
indent_style = unset
trim_trailing_whitespace = false
# Default behavior
* text=auto

# Maven Wrapper
/mvnw      text eol=lf
/mvnw.cmd  text eol=crlf

# Windows scripts
*.cmd text eol=crlf
*.bat text eol=crlf

# Java / Spring
*.java      text eol=lf
*.kt        text eol=lf
*.groovy    text eol=lf

# Config files
*.yml       text eol=lf
*.yaml      text eol=lf
*.properties text eol=lf
*.xml       text eol=lf

# Scripts
*.sh        text eol=lf
*.bat       text eol=crlf

# Docker
Dockerfile  text eol=lf

# Binary files (no diff, no merge)
*.jar       binary
*.war       binary
*.zip       binary
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.pdf       binary
